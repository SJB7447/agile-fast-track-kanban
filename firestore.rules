rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'sjb76337447@gmail.com'
      );
    }

    function isCreator() {
      return isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    function createdByMatchesAuth() {
      return request.resource.data.createdBy == request.auth.uid;
    }

    function immutableFieldsUnchanged() {
      return request.resource.data.createdAt == resource.data.createdAt &&
             request.resource.data.createdBy == resource.data.createdBy;
    }

    // ===============================================================
    // Tasks
    // ===============================================================
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && createdByMatchesAuth();
      allow update: if isAuthenticated() && immutableFieldsUnchanged();
      allow delete: if isCreator() || isAdmin();
    }

    // ===============================================================
    // Comments
    // ===============================================================
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.text is string &&
                    request.resource.data.text.size() >= 1 &&
                    request.resource.data.text.size() <= 2000;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
    }

    // ===============================================================
    // Announcements - admin write, all authenticated read
    // ===============================================================
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Admins
    // - read: any authenticated user (needed for isAdmin() checks and UI)
    // - create: only if invited via admin_invites OR bootstrapping initial admin
    // - update/delete: existing admin only
    // ===============================================================
    match /admins/{uid} {
      allow read: if isAuthenticated();
      // [SECURITY FIX] Must have an admin invite; prevents unauthorized self-elevation
      allow create: if isAuthenticated() &&
                    request.auth.uid == uid &&
                    exists(/databases/$(database)/documents/admin_invites/$(request.auth.token.email));
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // Admin invites
    // - read: admin OR the invited user themselves (to check their own invite status)
    // - write: admin only
    // ===============================================================
    match /admin_invites/{email} {
      // [SECURITY FIX] Was readable by ALL authenticated users — now restricted
      allow read: if isAdmin() ||
                  (isAuthenticated() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // ===============================================================
    // Projects - authenticated read, admin write
    // ===============================================================
    match /projects/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Meetings - all authenticated users can read/write/delete
    // ===============================================================
    match /meetings/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && createdByMatchesAuth();
      // [SECURITY FIX] Protect immutable fields on update
      allow update: if isAuthenticated() && immutableFieldsUnchanged();
      allow delete: if isCreator() || isAdmin();
    }

    // ===============================================================
    // Teams - admin write, authenticated read
    // ===============================================================
    match /teams/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // User-Team mapping
    // ===============================================================
    match /userTeams/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin() || request.auth.uid == uid;
    }

    // ===============================================================
    // Team invites
    // - read: admin OR the user whose email was invited (to check own invite)
    // - write: admin only
    // ===============================================================
    match /team_invites/{email} {
      // [SECURITY FIX] Was readable by ALL authenticated users — now restricted
      allow read: if isAdmin() ||
                  (isAuthenticated() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // ===============================================================
    // Calendar Events - all authenticated users can read/write/delete
    // ===============================================================
    match /calendarEvents/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && createdByMatchesAuth();
      allow delete: if isCreator() || isAdmin();
      allow update: if isAuthenticated() && immutableFieldsUnchanged();
    }

    // ===============================================================
    // Users - own profile R/W, admin reads all
    // ===============================================================
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ===============================================================
    // FCM Tokens
    // - read: own tokens only or admin (prevents token enumeration)
    // - create: authenticated, must match own uid
    // - delete: authenticated, must own the token
    // - update: never (tokens are replaced, not updated)
    // ===============================================================
    match /fcm_tokens/{tokenId} {
      // [SECURITY FIX] Was readable by ALL authenticated users — now restricted
      allow read: if isAdmin() ||
                  (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ===============================================================
    // Config - admin write, authenticated read
    // ===============================================================
    match /config/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
